# Copy to .env and fill in. Never commit the real .env.

# Supabase Postgres — Prisma
# Transaction pooler (port 6543) for the app at runtime:
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (port 5432) for migrations:
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase Auth (client-safe; protected by RLS)
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Service role key — SERVER ONLY, never expose to the browser. Used to view
# private verification IDs (signed URLs). Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Rate limiting (recommended for production) — Upstash Redis REST API.
# Without these, rate limiting is disabled (fails open). Create a free DB at
# upstash.com → your Redis DB → REST API → copy the URL + token.
UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<token>"

